#!/usr/bin/env node
// hoist-skill — emit scaffold capabilities into a consumer repo.
// Usage: node run [--names <n1,n2|all>] [--harness <claude|cursor|antigravity|all>]
//                [--into <path>] [--force] [--list]

import { readFileSync, writeFileSync, mkdirSync, existsSync, statSync } from 'node:fs';
import { join, dirname, resolve } from 'node:path';
import { fileURLToPath } from 'node:url';

const SCAFFOLD_ROOT = join(dirname(fileURLToPath(import.meta.url)), '../..');
const RESOLVER      = join(SCAFFOLD_ROOT, '.claude', 'skills', 'RESOLVER.md');
const HARNESSES     = ['claude', 'cursor', 'antigravity'];

// ---------------------------------------------------------------- args

const args = process.argv.slice(2);
const get  = (flag) => { const i = args.indexOf(flag); return i !== -1 ? args[i + 1] : null; };
const has  = (flag) => args.includes(flag);

const rawNames   = get('--names')   ?? 'all';
const rawHarness = get('--harness') ?? 'claude';
const intoRaw    = get('--into')    ?? '.';
const force      = has('--force');
const listMode   = has('--list');

const INTO = resolve(intoRaw);

// ---------------------------------------------------------------- RESOLVER parse

function splitRow(row) {
  const cells = [];
  let cur = '', inBt = false;
  for (const ch of row) {
    if (ch === '`') { inBt = !inBt; cur += ch; }
    else if (ch === '|' && !inBt) { cells.push(cur.trim()); cur = ''; }
    else { cur += ch; }
  }
  if (cur.trim()) cells.push(cur.trim());
  return cells.filter((c, i, a) => !(i === 0 && c === '') && !(i === a.length - 1 && c === ''));
}

function parseResolver() {
  const lines = readFileSync(RESOLVER, 'utf8').split('\n');
  const rows = [];
  let inTable = false;
  for (const line of lines) {
    const isRow = /^\s*\|.*\|\s*$/.test(line);
    if (!isRow) { if (inTable && line.trim()) break; continue; }
    const cells = splitRow(line);
    if (cells[0] === 'Skill') { inTable = true; continue; }
    if (/^-{2,}$/.test(cells[0]?.replace(/[:\s]/g, ''))) continue;
    if (!inTable || cells.length < 4) continue;
    rows.push({
      name: cells[0].replace(/`/g, ''),
      path: cells[2].replace(/`/g, ''),
      purpose: cells[3],
    });
  }
  return rows;
}

// ---------------------------------------------------------------- scaffold-keep

function loadKeep(dest) {
  const kf = join(dest, '.scaffold-keep');
  if (!existsSync(kf)) return () => false;
  const patterns = readFileSync(kf, 'utf8')
    .split('\n')
    .map(l => l.replace(/#.*/, '').trim())
    .filter(Boolean);
  return (rel) => patterns.some(p => {
    if (p.includes('*')) {
      const re = new RegExp('^' + p.replace(/\./g, '\\.').replace(/\*/g, '.*') + '$');
      return re.test(rel);
    }
    return rel === p || rel.startsWith(p + '/');
  });
}

// ---------------------------------------------------------------- clobber-safe write

function safeWrite(dest, relPath, content, kept, results) {
  if (kept(relPath)) {
    results.push({ path: relPath, status: 'kept' });
    console.error(`  kept   ${relPath}`);
    return;
  }
  const abs = join(dest, relPath);
  mkdirSync(dirname(abs), { recursive: true });
  if (existsSync(abs)) {
    const existing = readFileSync(abs, 'utf8');
    if (existing === content) {
      results.push({ path: relPath, status: 'unchanged' });
      console.error(`  unchanged  ${relPath}`);
      return;
    }
    if (!force) {
      const sidecar = abs + '.scaffold-new';
      writeFileSync(sidecar, content, 'utf8');
      results.push({ path: relPath, status: 'sidecar', sidecar: relPath + '.scaffold-new' });
      console.error(`  sidecar    ${relPath}.scaffold-new`);
      return;
    }
  }
  writeFileSync(abs, content, 'utf8');
  results.push({ path: relPath, status: 'written' });
  console.error(`  written    ${relPath}`);
}

// ---------------------------------------------------------------- per-harness emitters

function emitClaude(cap, dest, kept, results) {
  const bodyAbs = join(SCAFFOLD_ROOT, cap.path);
  safeWrite(dest, cap.path, readFileSync(bodyAbs, 'utf8'), kept, results);
  const wrapperRel = `.claude/skills/${cap.name}/SKILL.md`;
  const src = join(SCAFFOLD_ROOT, '.claude', 'skills', cap.name, 'SKILL.md');
  const content = existsSync(src)
    ? readFileSync(src, 'utf8')
    : `---\ndescription: ${cap.purpose}\n---\n\n@../../../${cap.path}\n`;
  safeWrite(dest, wrapperRel, content, kept, results);
}

function emitCursor(cap, dest, kept, results) {
  const bodyAbs = join(SCAFFOLD_ROOT, cap.path);
  safeWrite(dest, cap.path, readFileSync(bodyAbs, 'utf8'), kept, results);
  const cursorRel = `.cursor/rules/${cap.name}.mdc`;
  const src = join(SCAFFOLD_ROOT, '.cursor', 'rules', `${cap.name}.mdc`);
  const content = existsSync(src)
    ? readFileSync(src, 'utf8')
    : `---\ndescription: ${cap.purpose}\n---\n\n@../../${cap.path}\n`;
  safeWrite(dest, cursorRel, content, kept, results);
}

function emitAntigravity(cap, dest, kept, results) {
  const bodyAbs = join(SCAFFOLD_ROOT, cap.path);
  safeWrite(dest, cap.path, readFileSync(bodyAbs, 'utf8'), kept, results);

  const agentSkillRel = `.agents/skills/${cap.name}/SKILL.md`;
  const agentSkillSrc = join(SCAFFOLD_ROOT, '.agents', 'skills', cap.name, 'SKILL.md');
  const agentSkillContent = existsSync(agentSkillSrc)
    ? readFileSync(agentSkillSrc, 'utf8')
    : `---\nname: ${cap.name}\ndescription: |\n  ${cap.purpose}\nlicense: MIT\nmetadata:\n  version: "1.0"\n---\n\nRead and follow the complete skill instructions in [\`${cap.path}\`](../../../${cap.path}).\n`;
  safeWrite(dest, agentSkillRel, agentSkillContent, kept, results);

  const workflowRel = `.agent/workflows/${cap.name}.md`;
  const workflowSrc = join(SCAFFOLD_ROOT, '.agent', 'workflows', `${cap.name}.md`);
  const workflowContent = existsSync(workflowSrc)
    ? readFileSync(workflowSrc, 'utf8')
    : `---\ndescription: ${cap.purpose}\n---\n\nRead and follow the complete skill instructions in [\`${cap.path}\`](../../${cap.path}).\n`;
  safeWrite(dest, workflowRel, workflowContent, kept, results);
}

const EMITTERS = { claude: emitClaude, cursor: emitCursor, antigravity: emitAntigravity };

// ---------------------------------------------------------------- main

const registry = parseResolver();

if (listMode) {
  console.log(JSON.stringify({
    capabilities: registry.map(r => ({ name: r.name, purpose: r.purpose })),
    harnesses: HARNESSES,
  }, null, 2));
  process.exit(0);
}

// Resolve capability names
const requestedNames = rawNames === 'all' ? registry.map(r => r.name) : rawNames.split(',').map(s => s.trim());
const unknown = requestedNames.filter(n => !registry.find(r => r.name === n));
if (unknown.length) {
  console.error(`Unknown capabilities: ${unknown.join(', ')}`);
  console.error(`Available: ${registry.map(r => r.name).join(', ')}`);
  process.exit(1);
}

// Resolve harnesses
const requestedHarnesses = rawHarness === 'all' ? HARNESSES : [rawHarness];
const badHarnesses = requestedHarnesses.filter(h => !HARNESSES.includes(h));
if (badHarnesses.length) {
  console.error(`Unknown harnesses: ${badHarnesses.join(', ')}`);
  console.error(`Available: ${HARNESSES.join(', ')}`);
  process.exit(1);
}

const kept = loadKeep(INTO);
const results = [];

for (const name of requestedNames) {
  const cap = registry.find(r => r.name === name);
  for (const harness of requestedHarnesses) {
    console.error(`→ ${name} [${harness}]`);
    EMITTERS[harness](cap, INTO, kept, results);
  }
}

console.log(JSON.stringify({ into: INTO, harnesses: requestedHarnesses, results }, null, 2));
