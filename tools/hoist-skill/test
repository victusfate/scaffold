// ---------------------------------------------------------------- case 17: missing skill body gives actionable error

console.log('\nCase 17: missing skill body gives actionable error (P3)');
{
  // Build a partial mirror: has RESOLVER.md but lacks skills/tdd.md
  const fakeRoot = makeTmp();
  mkdirSync(join(fakeRoot, '.claude', 'skills'), { recursive: true });
  // Copy real RESOLVER.md so registry parsing works
  const realResolver = readFileSync(join(ROOT, '.claude', 'skills', 'RESOLVER.md'), 'utf8');
  writeFileSync(join(fakeRoot, '.claude', 'skills', 'RESOLVER.md'), realResolver, 'utf8');
  // Deliberately omit skills/tdd.md

  const dest = makeTmp();
  const r = spawnSync('node', [RUN, '--names', 'tdd', '--harness', 'claude', '--into', dest], {
    encoding: 'utf8',
    env: { ...process.env, HOIST_SCAFFOLD_ROOT: fakeRoot },
  });
  assert('exits non-zero', r.status !== 0, `status: ${r.status}`);
  assert('error mentions missing source', r.stderr.includes('missing source'), r.stderr);
  assert('error includes --fetch hint', r.stderr.includes('--fetch'), r.stderr);
  assert('error includes raw URL', r.stderr.includes('raw.githubusercontent.com'), r.stderr);
}

// ---------------------------------------------------------------- case 18: --fetch emits from a local HTTP server (P1)

console.log('\nCase 18: --fetch emits skills from a local HTTP file server');
{
  // The sandbox blocks fetch() in spawnSync children when the server lives in the
  // parent process. Workaround: start the server as a peer process via IPC so the
  // spawned tool can connect to it.
  const { spawn } = await import('node:child_process');

  const serverScript = `
    import { createServer } from 'node:http';
    import { readFile } from 'node:fs/promises';
    import { join } from 'node:path';
    const ROOT = ${JSON.stringify(ROOT)};
    createServer(async (req, res) => {
      const relPath = req.url.replace(/^\\/[^\\/]+\\//, '');
      try { const d = await readFile(join(ROOT, relPath)); res.writeHead(200); res.end(d); }
      catch { res.writeHead(404); res.end('not found'); }
    }).listen(0, '127.0.0.1', function() {
      process.send('ready:' + this.address().port);
    });
  `;

  const srv = spawn('node', ['--input-type=module'], {
    stdio: ['pipe', 'ignore', 'ignore', 'ipc'],
  });
  srv.stdin.end(serverScript);

  const serverPort = await new Promise(resolve => {
    srv.on('message', m => {
      if (String(m).startsWith('ready:')) resolve(Number(String(m).split(':')[1]));
    });
  });

  const dest = makeTmp();
  const r = spawnSync('node', [RUN, '--fetch', '--names', 'tdd', '--harness', 'claude', '--into', dest], {
    encoding: 'utf8',
    timeout: 15000,
    env: { ...process.env, HOIST_RAW_BASE: `http://127.0.0.1:${serverPort}` },
  });

  srv.kill();

  assert('--fetch exits 0', r.status === 0, r.stderr?.slice(0, 300));
  assert('--fetch: skill body written', existsSync(join(dest, 'skills/tdd.md')));
  assert('--fetch: claude wrapper written', existsSync(join(dest, '.claude/skills/tdd/SKILL.md')));

  let fetchOut;
  try { fetchOut = JSON.parse(r.stdout); } catch { fetchOut = null; }
  assert('--fetch: results array present', Array.isArray(fetchOut?.results));

  const manifestPath = join(dest, '.sync', 'hoisted');
  assert('--fetch: manifest recorded', existsSync(manifestPath));
}

// ---------------------------------------------------------------- case 19: --plan --from-manifest preserves pinned refs in sources

console.log('\nCase 19: --plan --from-manifest preserves pinned refs in sources');
{
  const dest = makeTmp();
  mkdirSync(join(dest, '.sync'), { recursive: true });
  writeFileSync(join(dest, '.sync', 'hoisted'),
    'feature-chain\tclaude\tv1.2.3\n');

  const r = spawnSync('node', [RUN, '--plan', '--from-manifest', '--into', dest], {
    encoding: 'utf8',
  });
  assert('exits 0', r.status === 0, r.stderr?.slice(0, 300));

  let out;
  try { out = JSON.parse(r.stdout); } catch { out = null; }
  assert('stdout is valid JSON', out !== null);

  const capSource = out?.sources?.find(s => s.path && !s.path.startsWith('.') && s.path !== 'tools/hoist-skill/run');
  assert('capability source has ref field', capSource?.ref !== undefined, JSON.stringify(capSource));
  assert('capability source ref matches manifest pin', capSource?.ref === 'v1.2.3', `got: ${capSource?.ref}`);
}

