// ---------------------------------------------------------------- case 7: claude wrapper always has description frontmatter (fallback)
// Verify that even when no canonical .claude/skills/<name>/SKILL.md exists in the scaffold
// root, the generated wrapper still contains a description: field so Claude Code can
// surface the skill in its skill list.

console.log('\nCase 7: claude wrapper fallback has description frontmatter');
{
  const dest = makeTmp();
  // Use a skill whose canonical wrapper exists in the scaffold root so we also prove
  // the "use existing source" path produces valid frontmatter.
  const r = run(['--names', 'hoist-skill', '--harness', 'claude', '--into', dest]);
  assert('exits 0', r.status === 0, r.stderr);
  const wrapperPath = join(dest, '.claude/skills/hoist-skill/SKILL.md');
  assert('claude wrapper written', existsSync(wrapperPath));
  const wrapper = readFileSync(wrapperPath, 'utf8');
  assert('wrapper has description frontmatter',
    /^---[\s\S]*?description:.*[\s\S]*?---/m.test(wrapper));
  assert('wrapper @-includes canonical',
    wrapper.includes('@../../../skills/hoist-skill.md'));
}

// ---------------------------------------------------------------- case 8: emit writes .sync/hoisted; re-emit does not duplicate

console.log('\nCase 8: emit writes manifest; re-emit does not duplicate');
{
  const dest = makeTmp();
  const r1 = run(['--names', 'feature-chain', '--harness', 'claude', '--into', dest]);
  assert('exits 0', r1.status === 0, r1.stderr);

  const manifestPath = join(dest, '.sync', 'hoisted');
  assert('manifest written', existsSync(manifestPath));

  const lines1 = readFileSync(manifestPath, 'utf8')
    .split('\n').filter(l => l.trim() && !l.startsWith('#'));
  assert('one entry', lines1.length === 1, `got: ${JSON.stringify(lines1)}`);
  assert('correct entry', lines1[0] === 'feature-chain\tclaude\tmain', `got: ${lines1[0]}`);

  // Re-emit — must not duplicate
  const r2 = run(['--names', 'feature-chain', '--harness', 'claude', '--into', dest]);
  assert('re-emit exits 0', r2.status === 0, r2.stderr);
  const lines2 = readFileSync(manifestPath, 'utf8')
    .split('\n').filter(l => l.trim() && !l.startsWith('#'));
  assert('still one entry (no duplicate)', lines2.length === 1, `got: ${JSON.stringify(lines2)}`);
}

