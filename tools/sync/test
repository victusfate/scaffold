// ---------------------------------------------------------------- slice 3: file promotion

import { promoteFiles } from './promote.mjs';
import { mkdtempSync, writeFileSync, mkdirSync, readFileSync, existsSync, rmSync } from 'node:fs';
import { tmpdir } from 'node:os';

function makeTmp() {
  return mkdtempSync(join(tmpdir(), 'sync-test-'));
}

function writeFile(dir, rel, content) {
  const abs = join(dir, rel);
  mkdirSync(dirname(abs), { recursive: true });
  writeFileSync(abs, content, 'utf8');
}

const POLICY_BASE = {
  ref: 'main',
  files: {
    copy: ['AGENTS.md'],
    guarded: [{ path: 'CLAUDE.md', keep_marker: '@MIND.md' }],
    protected: ['MIND.md'],
  },
  skills: { manifest: '.sync/hoisted' },
};

// Case 9: copy — differing destination gets a sidecar by default (clobber-safe)
{
  const src = makeTmp(), dst = makeTmp();
  writeFile(src, 'AGENTS.md', 'new content');
  writeFile(dst, 'AGENTS.md', 'old content');
  const results = await promoteFiles(POLICY_BASE, src, dst, {});
  const r = results.find(r => r.path === 'AGENTS.md');
  assert('case 9: copy writes sidecar when dest differs', r?.status === 'sidecar', r?.status);
  assert('case 9: dest untouched', readFileSync(join(dst, 'AGENTS.md'), 'utf8') === 'old content');
  assert('case 9: sidecar holds incoming', existsSync(join(dst, 'AGENTS.md.scaffold-new')) &&
    readFileSync(join(dst, 'AGENTS.md.scaffold-new'), 'utf8') === 'new content');
  rmSync(src, { recursive: true }); rmSync(dst, { recursive: true });
}

// Case 9b: copy — --force overwrites, no sidecar
{
  const src = makeTmp(), dst = makeTmp();
  writeFile(src, 'AGENTS.md', 'new content');
  writeFile(dst, 'AGENTS.md', 'old content');
  const results = await promoteFiles(POLICY_BASE, src, dst, { force: true });
  const r = results.find(r => r.path === 'AGENTS.md');
  assert('case 9b: force overwrites', r?.status === 'written', r?.status);
  assert('case 9b: content updated', readFileSync(join(dst, 'AGENTS.md'), 'utf8') === 'new content');
  assert('case 9b: no sidecar', !existsSync(join(dst, 'AGENTS.md.scaffold-new')));
  rmSync(src, { recursive: true }); rmSync(dst, { recursive: true });
}

// Case 9c: copy — .scaffold-keep entries are never written
{
  const src = makeTmp(), dst = makeTmp();
  writeFile(src, 'AGENTS.md', 'new content');
  writeFile(dst, 'AGENTS.md', 'mine');
  writeFile(dst, '.scaffold-keep', 'AGENTS.md\n');
  const results = await promoteFiles(POLICY_BASE, src, dst, { force: true });
  const r = results.find(r => r.path === 'AGENTS.md');
  assert('case 9c: kept path reported', r?.status === 'kept', r?.status);
  assert('case 9c: kept file untouched', readFileSync(join(dst, 'AGENTS.md'), 'utf8') === 'mine');
  assert('case 9c: no sidecar for kept', !existsSync(join(dst, 'AGENTS.md.scaffold-new')));
  rmSync(src, { recursive: true }); rmSync(dst, { recursive: true });
}

// Case 10: copy — unchanged when identical
{
  const src = makeTmp(), dst = makeTmp();
  writeFile(src, 'AGENTS.md', 'same');
  writeFile(dst, 'AGENTS.md', 'same');
  const results = await promoteFiles(POLICY_BASE, src, dst, {});
  const r = results.find(r => r.path === 'AGENTS.md');
  assert('case 10: copy unchanged when identical', r?.status === 'unchanged');
  rmSync(src, { recursive: true }); rmSync(dst, { recursive: true });
}

// Case 11: guarded — marker present, fresh destination → written
{
  const src = makeTmp(), dst = makeTmp();
  writeFile(src, 'CLAUDE.md', '@MIND.md\nsome content');
  const results = await promoteFiles(POLICY_BASE, src, dst, {});
  const r = results.find(r => r.path === 'CLAUDE.md');
  assert('case 11: guarded writes when marker present', r?.status === 'written', r?.status);
  rmSync(src, { recursive: true }); rmSync(dst, { recursive: true });
}

// Case 11b: guarded — marker present but destination differs → sidecar (clobber-safe)
{
  const src = makeTmp(), dst = makeTmp();
  writeFile(src, 'CLAUDE.md', '@MIND.md\nsome content');
  writeFile(dst, 'CLAUDE.md', 'old');
  const results = await promoteFiles(POLICY_BASE, src, dst, {});
  const r = results.find(r => r.path === 'CLAUDE.md');
  assert('case 11b: guarded sidecars when dest differs', r?.status === 'sidecar', r?.status);
  assert('case 11b: dest untouched', readFileSync(join(dst, 'CLAUDE.md'), 'utf8') === 'old');
  rmSync(src, { recursive: true }); rmSync(dst, { recursive: true });
}

// Case 12: guarded — skips when marker absent from incoming
{
  const src = makeTmp(), dst = makeTmp();
  writeFile(src, 'CLAUDE.md', 'no marker here');
  writeFile(dst, 'CLAUDE.md', 'local content');
  const results = await promoteFiles(POLICY_BASE, src, dst, {});
  const r = results.find(r => r.path === 'CLAUDE.md');
  assert('case 12: guarded skips when marker absent', r?.status === 'guarded-skip');
  assert('case 12: local file untouched', readFileSync(join(dst, 'CLAUDE.md'), 'utf8') === 'local content');
  rmSync(src, { recursive: true }); rmSync(dst, { recursive: true });
}

// Case 13: protected — never written even with --force
{
  const src = makeTmp(), dst = makeTmp();
  writeFile(src, 'MIND.md', 'from scaffold');
  writeFile(dst, 'MIND.md', 'my content');
  const results = await promoteFiles(POLICY_BASE, src, dst, { force: true });
  const r = results.find(r => r.path === 'MIND.md');
  assert('case 13: protected never written', r?.status === 'protected');
  assert('case 13: protected file untouched', readFileSync(join(dst, 'MIND.md'), 'utf8') === 'my content');
  rmSync(src, { recursive: true }); rmSync(dst, { recursive: true });
}

// Case 14: default deny — unlisted path not written
{
  const src = makeTmp(), dst = makeTmp();
  writeFile(src, 'AGENTS.md', 'agents');
  writeFile(src, 'UNLISTED.md', 'should not copy');
  const results = await promoteFiles(POLICY_BASE, src, dst, {});
  assert('case 14: unlisted path not in results', !results.find(r => r.path === 'UNLISTED.md'));
  assert('case 14: unlisted file not written', !existsSync(join(dst, 'UNLISTED.md')));
  rmSync(src, { recursive: true }); rmSync(dst, { recursive: true });
}

// Case 15: --check mode — no files written, actions reported
{
  const src = makeTmp(), dst = makeTmp();
  writeFile(src, 'AGENTS.md', 'new');
  writeFile(dst, 'AGENTS.md', 'old');
  writeFile(src, 'CLAUDE.md', '@MIND.md content');
  const results = await promoteFiles(POLICY_BASE, src, dst, { check: true });
  const r = results.find(r => r.path === 'AGENTS.md');
  assert('case 15: check mode reports would-sidecar for differing dest', r?.status === 'would-sidecar', r?.status);
  const rc = results.find(r => r.path === 'CLAUDE.md');
  assert('case 15: check mode reports would-write for fresh dest', rc?.status === 'would-write', rc?.status);
  assert('case 15: check mode writes nothing', readFileSync(join(dst, 'AGENTS.md'), 'utf8') === 'old');
  assert('case 15: check mode writes no sidecar', !existsSync(join(dst, 'AGENTS.md.scaffold-new')));
  rmSync(src, { recursive: true }); rmSync(dst, { recursive: true });
}

// Case 16: source file missing — skipped gracefully
{
  const src = makeTmp(), dst = makeTmp();
  // AGENTS.md is in policy.copy but not in src
  const results = await promoteFiles(POLICY_BASE, src, dst, {});
  const r = results.find(r => r.path === 'AGENTS.md');
  assert('case 16: missing src file reported as skipped', r?.status === 'src-missing');
  rmSync(src, { recursive: true }); rmSync(dst, { recursive: true });
}

// ---------------------------------------------------------------- slice 4: hoist-skill API export

// Case 16a: hoist() is importable from the .mjs engine module (works on Node 18+,
// unlike an extensionless ESM import)
let hoist;
{
  try {
    ({ hoist } = await import('../hoist-skill/hoist.mjs'));
  } catch { /* fall through */ }
  assert('case 16a: hoist.mjs exports hoist()', typeof hoist === 'function');
}

// Case 17: hoist() is importable and list mode returns capabilities JSON
{
  let result;
  try {
    result = await hoist({ list: true, into: makeTmp() });
  } catch (e) {
    assert('case 17: hoist() importable', false, e.message);
  }
  if (result !== undefined) {
    assert('case 17: hoist list returns capabilities', Array.isArray(result?.capabilities) && result.capabilities.length > 0,
      JSON.stringify(result));
  }
}

// Case 18: hoist() throws on unknown capability in manifest (no network needed)
{
  const dst = makeTmp();
  const manifestPath = join(dst, '.sync', 'hoisted');
  mkdirSync(join(dst, '.sync'), { recursive: true });
  writeFileSync(manifestPath, '# header\nno-such-skill\tclaude\tmain\n', 'utf8');
  let errMsg = '';
  try {
    await hoist({ fromManifest: manifestPath, into: dst });
  } catch (e) { errMsg = e.message; }
  assert('case 18: hoist() throws on unknown manifest entry', errMsg.includes('Unknown capabilities'));
  rmSync(dst, { recursive: true });
}

// ---------------------------------------------------------------- slice 5: sync orchestrator

// Case 19: missing policy file → exit 1 with clear message
{
  const dst = makeTmp();
  const r = run(['--into', dst]);
  assert('case 19: missing policy exits 1', r.code === 1);
  assert('case 19: missing policy message', r.stderr.includes('policy') || r.stdout.includes('policy'),
    `stderr: ${r.stderr}\nstdout: ${r.stdout}`);
  rmSync(dst, { recursive: true });
}

// Case 20: provenance line printed before writes
{
  const src = makeTmp(), dst = makeTmp();
  writeFile(src, 'AGENTS.md', 'content');

  const policyYaml = [
    'ref: test-ref',
    'files:',
    '  copy:',
    '    - AGENTS.md',
    'skills:',
    '  manifest: .sync/hoisted',
  ].join('\n');
  writeFile(dst, '.sync/policy.yaml', policyYaml);

  const r = run(['--into', dst, '--ref', 'test-ref', '--check', `--scaffold-root=${src}`]);
  assert('case 20: provenance ref in output', r.stdout.includes('test-ref') || r.stderr.includes('test-ref'),
    `stdout: ${r.stdout}\nstderr: ${r.stderr}`);
  rmSync(src, { recursive: true }); rmSync(dst, { recursive: true });
}

// Case 21: --check prints summary, exits 0
{
  const src = makeTmp(), dst = makeTmp();
  writeFile(src, 'AGENTS.md', 'new content');
  writeFile(dst, 'AGENTS.md', 'old content');

  const policyYaml = [
    'files:',
    '  copy:',
    '    - AGENTS.md',
    'skills:',
    '  manifest: .sync/hoisted',
  ].join('\n');
  writeFile(dst, '.sync/policy.yaml', policyYaml);

  const r = run(['--into', dst, '--check', `--scaffold-root=${src}`]);
  assert('case 21: --check exits 0', r.code === 0, `exit ${r.code}\n${r.stderr}`);
  const content21 = existsSync(join(dst, 'AGENTS.md')) ? readFileSync(join(dst, 'AGENTS.md'), 'utf8') : '(missing)';
  assert('case 21: --check does not write', content21 === 'old content', `got: ${content21}`);
  rmSync(src, { recursive: true }); rmSync(dst, { recursive: true });
}

// Case 22: skills section absent from policy → hoist not called, sync succeeds
{
  const src = makeTmp(), dst = makeTmp();
  writeFile(src, 'AGENTS.md', 'agents content');

  const policyYaml = [
    'files:',
    '  copy:',
    '    - AGENTS.md',
    'skills:',
    '  manifest: .sync/hoisted',
  ].join('\n');
  writeFile(dst, '.sync/policy.yaml', policyYaml);
  // No .sync/hoisted manifest — hoist should be skipped

  const r = run(['--into', dst, `--scaffold-root=${src}`]);
  assert('case 22: sync without manifest exits 0', r.code === 0, `exit ${r.code}\n${r.stderr}`);
  const content22 = existsSync(join(dst, 'AGENTS.md')) ? readFileSync(join(dst, 'AGENTS.md'), 'utf8') : '(missing)';
  assert('case 22: copy file written', content22 === 'agents content', `got: ${content22}`);
  rmSync(src, { recursive: true }); rmSync(dst, { recursive: true });
}

// ---------------------------------------------------------------- slice: sync UX truthfulness

// Case 23: provenance names the file source and the skills ref distinctly
{
  const src = makeTmp(), dst = makeTmp();
  writeFile(src, 'AGENTS.md', 'content');
  writeFile(dst, '.sync/policy.yaml', 'files:\n  copy:\n    - AGENTS.md\nskills:\n  manifest: .sync/hoisted');
  const r = run(['--into', dst, '--ref', 'vX', '--check', `--scaffold-root=${src}`]);
  assert('case 23: provenance has files= source', r.stdout.includes('files='), r.stdout);
  assert('case 23: provenance has skills-ref=', r.stdout.includes('skills-ref=vX'), r.stdout);
  rmSync(src, { recursive: true }); rmSync(dst, { recursive: true });
}

// Case 24: --check reports the skills step instead of pretending to hoist
{
  const src = makeTmp(), dst = makeTmp();
  writeFile(src, 'AGENTS.md', 'content');
  writeFile(dst, '.sync/policy.yaml', 'files:\n  copy:\n    - AGENTS.md\nskills:\n  manifest: .sync/hoisted');
  writeFile(dst, '.sync/hoisted', '# header\ntdd\tclaude\tmain\nsimplify\tclaude\tmain\n');
  const r = run(['--into', dst, '--check', `--scaffold-root=${src}`]);
  assert('case 24: --check exits 0', r.code === 0, `exit ${r.code}\n${r.stderr}`);
  assert('case 24: --check reports replay count', /would-replay\s+2 skill/.test(r.stdout), r.stdout);
  assert('case 24: --check does not claim hoisting', !r.stdout.includes('hoisting skills'), r.stdout);
  rmSync(src, { recursive: true }); rmSync(dst, { recursive: true });
}

// Case 25: local --scaffold-root hoists skills from that tree, no network
{
  const dst = makeTmp();
  writeFile(dst, '.sync/policy.yaml', 'files:\n  copy:\n    - AGENTS.md\nskills:\n  manifest: .sync/hoisted');
  writeFile(dst, '.sync/hoisted', 'tdd\tclaude\tmain\n');
  const r = run(['--into', dst, `--scaffold-root=${ROOT}`],
    { env: { ...process.env, HOIST_RAW_BASE: 'http://127.0.0.1:9' } });
  assert('case 25: local-root sync exits 0', r.code === 0, `exit ${r.code}\n${r.stderr}`);
  assert('case 25: skill body hoisted locally', existsSync(join(dst, 'skills/tdd.md')));
  assert('case 25: claude wrapper hoisted locally', existsSync(join(dst, '.claude/skills/tdd/SKILL.md')));
  rmSync(dst, { recursive: true });
}

// Case 26: ../ traversal path in copy list → traversal-blocked, legitimate path still written
{
  const src = makeTmp(), dst = makeTmp();
  writeFile(src, 'AGENTS.md', 'agents');
  const policy = parsePolicy([
    'files:',
    '  copy:',
    '    - AGENTS.md',
    '    - ../escape.txt',
    'skills:',
    '  manifest: .sync/hoisted',
  ].join('\n'));
  const results = promoteFiles(policy, src, dst);
  const blocked = results.find(r => r.path === '../escape.txt');
  assert('case 26: traversal path status is traversal-blocked', blocked?.status === 'traversal-blocked',
    `status: ${blocked?.status}`);
  assert('case 26: normal file still written', existsSync(join(dst, 'AGENTS.md')));
  rmSync(src, { recursive: true }); rmSync(dst, { recursive: true });
}

console.error(`\n${passed} passed, ${failed} failed`);
process.exit(failed ? 1 : 0);
